# Server .env — copy to project root on Proxmox VM as `.env`
#   cp backend/.env.example .env   (or copy backend/.env and edit)
#
# PostgreSQL on 192.168.22.111 (pgAdmin: http://192.168.22.111/browser/)

DB_HOST=192.168.22.111
DB_PORT=5432
DB_NAME=moca-test-db
DB_USER=duylong
DB_PASSWORD=duylongadminpass
SERVER_PORT=8080

MINIO_ENABLED=false
MINIO_ENDPOINT=http://your-minio-host:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=moca-drawings
MINIO_AUTO_CREATE_BUCKET=false

REDIS_ENABLED=true
REDIS_HOST=redis.duylong.art
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_SSL=true
